# GiftOS Core Environment Configuration
# Copy this file to .env and fill in your values

# ── Application ──
APP_NAME=GiftOS Core
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-256-bit-random-string

# ── Database ──
DATABASE_URL=postgresql+asyncpg://giftos:giftos@postgres:5432/giftos
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ──
REDIS_URL=redis://redis:6379/0
REDIS_POOL_SIZE=50

# ── Celery ──
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── NoOnes API ──
NOONES_CLIENT_ID=your-noones-client-id
NOONES_CLIENT_SECRET=your-noones-client-secret
NOONES_API_BASE=https://api.noones.com
NOONES_AUTH_URL=https://auth.noones.com/oauth2/token
NOONES_WEBHOOK_SECRET=your-webhook-signing-secret

# ── API Security ──
API_RATE_LIMIT=100/minute
API_KEY_HEADER=X-API-Key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Scrapers ──
SCRAPER_INTERVAL_SECONDS=60
SCRAPER_TIMEOUT_SECONDS=30
USER_AGENT=GiftOS-Market-Intelligence/0.1.0

# ── Notifications ──
TELEGRAM_BOT_TOKEN=
WHATSAPP_API_KEY=
ALERT_WEBHOOK_URL=

# ── Monitoring ──
SENTRY_DSN=
LOG_LEVEL=INFO
